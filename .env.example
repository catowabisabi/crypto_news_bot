# OpenAI API Keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_STOCK=your_openai_api_key_for_stock_mode_here

# Telegram Bot Tokens
TELEGRAM_TOKEN=your_telegram_token_here
TELEGRAM_TOKEN_STOCK=your_telegram_token_for_stock_mode_here

# Telegram Chat IDs
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_CHAT_ID_STOCK=your_telegram_chat_id_for_stock_mode_here

# Your Telegram User ID (for bot access control)
USER_ID=your_telegram_user_id_here

# MongoDB Connection String
MONGODB_CONNECTION_STRING=mongodb+srv://username:password@cluster-url/?retryWrites=true&w=majority&tls=true&tlsAllowInvalidCertificates=true

# News Category: crypto or stock
NEWS_CATEGORY=crypto

# Web UI Settings
ENABLE_WEB_UI=true
WEB_UI_PORT=5000

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Database Names
DATABASE_NAME=cato_trading_crypto
DATABASE_NAME_STOCK=cato_trading_stock
